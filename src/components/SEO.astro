---
import { cars, company } from '../data/cars.js';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'JRcars — Automóveis Usados Certificados em Lisboa e Porto',
  description = company.description,
  image = 'https://images.unsplash.com/photo-1617531653332-bd46c24f2068?w=1200&q=85',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;

// JSON-LD: stand automóvel (AutoDealer) com localizações + lista de viaturas
const dealerLd = {
  '@context': 'https://schema.org',
  '@type': 'AutoDealer',
  name: company.name,
  legalName: company.legalName,
  description: company.description,
  url: company.url,
  telephone: company.phone,
  email: company.email,
  image,
  priceRange: '€€€',
  areaServed: 'PT',
  location: company.locations.map((l) => ({
    '@type': 'AutomotiveBusiness',
    name: `${company.name} ${l.city}`,
    telephone: l.phone,
    address: {
      '@type': 'PostalAddress',
      streetAddress: l.street,
      addressLocality: l.city,
      postalCode: l.postal,
      addressCountry: 'PT',
    },
    openingHours: 'Mo-Su 09:00-20:00',
  })),
};

const inventoryLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Viaturas disponíveis — JRcars',
  numberOfItems: cars.length,
  itemListElement: cars.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Car',
      name: c.name,
      brand: { '@type': 'Brand', name: c.brand },
      ...(c.year ? { vehicleModelDate: String(c.year) } : {}),
      fuelType: c.fuel,
      ...(c.km > 0 ? { mileageFromOdometer: { '@type': 'QuantitativeValue', value: c.km, unitCode: 'KMT' } } : {}),
      image: c.img,
      offers: {
        '@type': 'Offer',
        price: c.price,
        priceCurrency: 'EUR',
        availability: 'https://schema.org/InStock',
        itemCondition: 'https://schema.org/UsedCondition',
      },
    },
  })),
};
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="theme-color" content="#14161a" />
<meta name="author" content={company.name} />
<meta name="keywords" content="carros usados, automóveis usados, stand de carros, financiamento automóvel, retoma, Lisboa, Porto, viaturas certificadas, JRcars" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={company.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={image} />
<meta property="og:locale" content="pt_PT" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- PWA -->
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
<meta name="application-name" content="JRcars" />
<meta name="apple-mobile-web-app-title" content="JRcars" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Schibsted+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet" />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(dealerLd)} />
<script type="application/ld+json" set:html={JSON.stringify(inventoryLd)} />
